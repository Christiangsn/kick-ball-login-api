{
    "compilerOptions": 
    {
      "target": "ESNext",
      "module": "CommonJS",
      "moduleResolution": "node",
      "outDir": "./bin",
      "baseUrl": "./",
       "experimentalDecorators": true,
       "esModuleInterop": true,
       "allowSyntheticDefaultImports": true,
       "skipLibCheck": true,
       "typeRoots": [
         "./node_modules/@types",
         "./src/@types/logger.d.ts"
       ]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "bin"]
} 